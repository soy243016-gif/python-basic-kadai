      "source": [
        "# 台形の面積を求める\n",
        "\n",
        "# 単位は ㎝\n",
        "top_base = 10\n",
        "bottom_base = 20\n",
        "height = 5\n",
        "\n",
        "# 公式　面積＝（上底＋下底）×高さ÷２\n",
        "area = (top_base + bottom_base) * height / 2\n",
        "\n",
        "print(f\"{area} cm²\")"
      ]
    }
  ]
