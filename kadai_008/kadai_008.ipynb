      "source": [
        "# 条件分岐（if分）でFizzBuzzを書く\n",
        "\n",
        "var = 30  # ここに条件判定対象の正の整数を入れる\n",
        "\n",
        "if var % 3 == 0 and var % 5 == 0:\n",
        "    print(\"FizzBuzz\")\n",
        "elif var % 3 == 0:\n",
        "    print(\"Fizz\")\n",
        "elif var % 5 == 0:\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    print(var)"
      ]
    }
  ]
